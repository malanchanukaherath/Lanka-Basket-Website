# Root Docker env file for docker-compose.yml\n# Copy to .env and fill real values before running Docker\n\n# Frontend build-time variables\nVITE_API_URL=http://localhost:8080\nVITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-publishable-key\n\n# Backend runtime variables\nMONGODB_URI=mongodb://mongo:27017/lanka_basket\nFRONTEND_URL=http://localhost\n\nSECRET_KEY_ACCESS_TOKEN=replace-with-secure-access-secret\nSECRET_KEY_REFRESH_TOKEN=replace-with-secure-refresh-secret\nJWT_SECRET=replace-with-secure-jwt-secret\nJWT_REFRESH_SECRET=replace-with-secure-jwt-refresh-secret\n\nBREVO_API_KEY=replace-with-brevo-api-key\nEMAIL_USER=replace-with-brevo-user\nEMAIL_PASS=replace-with-brevo-password\n\nCLOUDINARY_CLOUD_NAME=replace-with-cloudinary-name\nCLOUDINARY_API_KEY=replace-with-cloudinary-key\nCLOUDINARY_API_SECRET=replace-with-cloudinary-secret\n\nSTRIPE_SECRET_KEY=replace-with-stripe-secret\nSTRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret\n\nCSRF_SECRET=replace-with-strong-csrf-secret\nSESSION_SECRET=replace-with-strong-session-secret\n